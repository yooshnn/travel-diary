<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.td.traveldiary.domain.region.repository.SidoRepository">

    <select id="findAll" resultType="com.td.traveldiary.domain.region.entity.Sido">
        SELECT id, name, code
        FROM sido
        ORDER BY id
    </select>

</mapper>